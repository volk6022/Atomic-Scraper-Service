# --- Internal Auth ---
API_KEY=default_internal_key
REDIS_URL=redis://localhost:6379
PORT=8000

# --- Extraction Settings (e.g., Jina Reader LM) ---
EXTRACTION_API_BASE=http://localhost:1234/v1
EXTRACTION_API_KEY=lm-studio
EXTRACTION_MODEL_NAME=jinaai.readerlm-v2

# --- Orchestration Settings (reasoning/navigation) ---
ORCHESTRATION_API_BASE=https://api.openai.com/v1
ORCHESTRATION_API_KEY=sk-...
ORCHESTRATION_MODEL_NAME=gpt-4o

# --- Scraper Settings ---
BROWSER_TIMEOUT=30000
SESSION_INACTIVITY_TIMEOUT=600
MAX_CONCURRENT_RESEARCH_TASKS=5

# --- Rate Limiting (optional) ---
# RATE_LIMIT_YANDEX_PER_HOUR=30
# RATE_LIMIT_DEFAULT_PER_HOUR=1000

# --- Research Agent (flat-loop) — all optional, defaults match production v2.1 ---
# RESEARCH_COMPACT_TRIGGER_TOKENS=50000
# RESEARCH_MAX_COMPACTIONS=3
# RESEARCH_SOFT_ELIDE_AFTER_TURNS=4
# RESEARCH_REFRASER_EVERY_N_SERPS=15
# RESEARCH_DOMAIN_FAIL_THRESHOLD=3
# RESEARCH_LLM_TIMEOUT_S=180.0
# RESEARCH_SCRAPE_BUDGET_CHARS=3500
# RESEARCH_CRITIC_PASS_SCORE=8.5
# RESEARCH_MAX_SUBMIT_REJECTS=2
# RESEARCH_DEFAULT_LANGUAGE=ru
# RESEARCH_DEFAULT_SERP_K=6
# RESEARCH_DOMAINS_NEVER_BLOCK=yandex.ru,2gis.ru,hh.ru,vk.com,t.me
# RESEARCH_PROMPTS_PATH=src/actions/research/research_agent_prompts.yaml
