# ── Redis ────────────────────────────────────────────────────────
SCRAPER_REDIS_URL=redis://localhost:6379/0

# ── Stateless Pool: Server-side proxy rotation ───────────────────
# Format: ["http://user:pass@host:port", "socks5://user:pass@host:port"]
SCRAPER_SERPER_PROXIES=[]

# ── Stateful Sessions ────────────────────────────────────────────
SCRAPER_SESSION_TIMEOUT_SECONDS=300
SCRAPER_SESSION_MAX_DURATION_SECONDS=3600

# ── Browser Defaults ─────────────────────────────────────────────
SCRAPER_BROWSER_HEADLESS=True
SCRAPER_DEFAULT_VIEWPORT_WIDTH=1920
SCRAPER_DEFAULT_VIEWPORT_HEIGHT=1080
SCRAPER_DEFAULT_USER_AGENT=

# ── Taskiq Workers ───────────────────────────────────────────────
SCRAPER_STATELESS_WORKERS_COUNT=2

# ── LLM / External Services ──────────────────────────────────────
SCRAPER_OPENAI_API_KEY=your_openai_api_key_here
SCRAPER_OPENAI_BASE_URL=
SCRAPER_JINA_API_URL=
SCRAPER_JINA_API_KEY=
SCRAPER_OMNI_PARSER_URL=
