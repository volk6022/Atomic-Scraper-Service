# --- Internal Auth ---
API_KEY=default_internal_key
# Inside the docker-compose network, Redis is reachable via the service name.
REDIS_URL=redis://localhost:16379
REDIS_HOST=localhost
REDIS_PORT=16379
PORT=8000

# --- Extraction Settings (Jina Reader LM — html→md) ---
EXTRACTION_API_BASE=http://localhost:20022/v1/
EXTRACTION_API_KEY=lm-studio
EXTRACTION_MODEL_NAME=qwen3.5-9b-claude-4.6-opus-reasoning-distilled

# --- Orchestration Settings (reasoning/navigation — research agent LLM) ---
ORCHESTRATION_API_BASE=http://localhost:20022/v1/
ORCHESTRATION_API_KEY=lm-studio
ORCHESTRATION_MODEL_NAME=qwen3.5-9b-claude-4.6-opus-reasoning-distilled

# --- Scraper Settings ---
BROWSER_TIMEOUT=30000
SESSION_INACTIVITY_TIMEOUT=600

# --- Rate Limiting (optional) ---
# RATE_LIMIT_YANDEX_PER_HOUR=30
RATE_LIMIT_DEFAULT_PER_HOUR=100000
MAX_CONCURRENT_RESEARCH_TASKS=10

# --- SearXNG client tuning (based on serp_experiment/REPORT_searxng.md) ---
SEARXNG_MIN_ORGANIC=3
SEARXNG_RETRY_DELAY=1.0
SEARXNG_MAX_RETRIES=2
SEARXNG_TIMEOUT=15.0
